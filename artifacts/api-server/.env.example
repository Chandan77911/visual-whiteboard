# ─────────────────────────────────────────────────────────────
#  K-Space API Server — Environment Variables (Appwrite)
# ─────────────────────────────────────────────────────────────
#
# SETUP:
#   1. Install Appwrite Desktop: https://appwrite.io/docs/sdks#desktop
#      OR run via Docker: docker run -it --rm appwrite/appwrite
#   2. Create a project in Appwrite Console (http://localhost/console)
#   3. Create a database and 6 collections (see README)
#   4. Generate an API key with Database permissions
#   5. Copy this file: copy .env.example .env
#   6. Fill in values below
# ─────────────────────────────────────────────────────────────

# Appwrite server URL (default for local install)
APPWRITE_ENDPOINT=http://localhost/v1

# Your Appwrite Project ID (from Project Settings)
APPWRITE_PROJECT_ID=your_project_id

# Your Appwrite API Key (from Project Settings → API Keys)
APPWRITE_API_KEY=your_api_key

# Your Appwrite Database ID (created in step 3)
APPWRITE_DATABASE_ID=kspace

# OpenAI API Key (for AI features — optional, app works without it)
OPENAI_API_KEY=sk-...

# Server port
PORT=5000
