# ─────────────────────────────────────────────
#  Visual Whiteboard — Backend Environment
# ─────────────────────────────────────────────
#
# HOW TO USE:
#   1. Copy this file → rename to  .env
#   2. Fill in values below
#   3. Run:  npm run dev
#
# ─────────────────────────────────────────────

PORT=3001

# Frontend URL (leave as-is for local dev)
CLIENT_URL=http://localhost:5173

# ── Redis (OPTIONAL) ──────────────────────────
# Leave this blank on Windows — app uses fast
# in-memory storage automatically. No Redis needed!
#
# Only set this if you have Redis running:
# REDIS_URL=redis://localhost:6379
REDIS_URL=

# ── OpenAI (OPTIONAL) ─────────────────────────
# Enables real AI suggestions in Architecture Assist.
# Leave blank to use built-in smart suggestions instead.
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
